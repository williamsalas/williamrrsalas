{
  "name": "PR VM",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {},
    "ghcr.io/devcontainers/features/node:1": { "version": "22" }
  },
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": { "label": "site", "onAutoForward": "openBrowser" }
  },
  "postCreateCommand": "npm install && nohup npx vite --host >/tmp/server.log 2>&1 &"
}
